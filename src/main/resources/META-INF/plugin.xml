<idea-plugin>
    <id>com.github.youjiyun1123.youregexinterpreter</id>
    <name>You Regex Interpreter</name>
    <vendor>youjiyun1123</vendor>
    <description><![CDATA[
        <p><b>You Regex Interpreter</b> is an IntelliJ IDEA plugin that helps developers understand, debug, and test regular expressions instantly within the IDE.</p>
        <p>Features:</p>
        <ul>
            <li>Natural language explanation of regex patterns</li>
            <li>Real-time match testing with highlighting</li>
            <li>Syntax error detection and position marking</li>
            <li>Structured regex visualization</li>
            <li>30+ built-in regex templates</li>
            <li>Multi-language support (Java, JavaScript, Python)</li>
            <li>Syntax tree visualization</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.YouRegexBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.youjiyun1123.youregexinterpreter.ui.RegexToolWindowFactory" id="RegexToolWindow" anchor="right" secondary="false" stripeTitle="%tool.window.title"/>
    </extensions>

    <actions>
        <!-- Open Tool Window -->
        <action id="YouRegexInterpreter.OpenToolWindow" class="com.github.youjiyun1123.youregexinterpreter.action.OpenRegexToolWindowAction"
                text="%action.YouRegexInterpreter.OpenToolWindow.text" description="%action.YouRegexInterpreter.OpenToolWindow.description">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift R"/>
        </action>
        
        <!-- Analyze Selected Regex -->
        <action id="YouRegexInterpreter.AnalyzeSelection" class="com.github.youjiyun1123.youregexinterpreter.action.AnalyzeRegexAction"
                text="%action.YouRegexInterpreter.AnalyzeSelection.text" description="%action.YouRegexInterpreter.AnalyzeSelection.description">
            <add-to-group group-id="EditorPopupMenu" anchor="last" separator-after="true"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift G"/>
        </action>
        
        <!-- Analyze from Clipboard -->
        <action id="YouRegexInterpreter.AnalyzeClipboard" class="com.github.youjiyun1123.youregexinterpreter.action.AnalyzeFromClipboardAction"
                text="%action.YouRegexInterpreter.AnalyzeClipboard.text" description="%action.YouRegexInterpreter.AnalyzeClipboard.description">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
